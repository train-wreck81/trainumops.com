<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trainum Optimization Partners | AI-Powered Optimization for Operations-Heavy Industries</title>
    <style>
        :root {
            --dark-navy: #0d0d1a;
            --charcoal: #1a1a20;
            --electric-blue: #00c8e6;
            --white: #ffffff;
            --light-gray: #f0f0f0;
        }
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--dark-navy);
            color: var(--white);
            line-height: 1.6;
            overflow-x: hidden;
            scroll-behavior: smooth;
        }
        .logo {
            font-size: 2.5rem;
            font-weight: 700;
            color: var(--electric-blue);
            text-decoration: none;
            margin: 1rem;
            display: inline-block;
        }
        .logo span {
            color: var(--white);
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem 1rem;
        }
        .hero {
            padding: 6rem 0;
            text-align: center;
            position: relative;
        }
        .hero h1 {
            font-size: 3rem;
            margin-bottom: 1rem;
            font-weight: 800;
        }
        .hero p {
            font-size: 1.25rem;
            max-width: 800px;
            margin: 0 auto 2rem;
            line-height: 1.8;
        }
        .cta-btn {
            display: inline-block;
            background: var(--electric-blue);
            color: var(--white);
            padding: 1rem 2rem;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            font-size: 1.1rem;
            transition: all 0.3s ease;
            margin-top: 1rem;
            box-shadow: 0 5px 15px rgba(0, 200, 230, 0.4);
        }
        .cta-btn:hover {
            background: #00b3d9;
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0, 200, 230, 0.6);
        }
        .section {
            padding: 4rem 0;
        }
        .section-title {
            text-align: center;
            font-size: 2.5rem;
            margin-bottom: 3rem;
            position: relative;
            font-weight: 700;
        }
        .section-title::after {
            content: '';
            display: inline-block;
            width: 80px;
            height: 5px;
            background: var(--electric-blue);
            margin: 0 auto;
        }
        .services, .industries, .featured, .about, .contact {
            padding: 0 0 0;
            background: var(--charcoal);
        }
        .services .service-item,
        .industries .industry-item,
        .featured .item,
        .about .item,
        .contact .item {
            display: flex;
            flex-direction: column;
            padding: 2rem;
            margin: 2rem 0;
            background: var(--light-gray);
            border-radius: 10px;
            transition: all 0.3s ease;
        }
        .services .service-item:hover,
        .industries .industry-item:hover,
        .featured .item:hover,
        .about .item:hover,
        .contact .item:hover {
            transform: translateY(-10px);
            box-shadow: 0 10px 30px rgba(0, 200, 230, 0.2);
        }
        .service-item h3,
        .industry-item h3,
        .item h3,
        .item p,
        .item .cta {
            margin: 0;
            padding: 0;
        }
        .service-item p,
        .industry-item p,
        .item p {
            font-size: 1.1rem;
            margin: 1rem 0;
        }
        .cta {
            display: inline-block;
            background: var(--electric-blue);
            color: var(--white);
            padding: 0.5rem 1rem;
            border-radius: 5px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
        }
        .cta:hover {
            background: #00b3d9;
            transform: scale(1.05);
        }
        .industries ul {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 1.5rem;
            list-style: none;
        }
        .industries li {
            font-size: 1.1rem;
            padding: 0.5rem 1rem;
            border-radius: 20px;
            background: rgba(0, 200, 230, 0.1);
            transition: all 0.3s ease;
        }
        .industries li:hover {
            background: var(--electric-blue);
            color: var(--white);
        }
        .featured-offering {
            text-align: center;
        }
        .featured-offering h2 {
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }
        .featured-offering p {
            font-size: 1.1rem;
            margin-bottom: 1.5rem;
            line-height: 1.7;
        }
        .contact-form {
            max-width: 600px;
            margin: 2rem auto;
        }
        .contact-form form {
            display: flex;
            flex-direction: column;
        }
        .contact-form input,
        .contact-form textarea {
            margin: 1rem 0;
            padding: 1rem;
            border-radius: 5px;
            border: none;
            font-size: 1rem;
            background: rgba(255,255,255,0.1);
            color: var(--white);
            transition: all 0.3s ease;
        }
        .contact-form input:focus,
        .contact-form textarea:focus {
            background: rgba(255,255,255,0.2);
            box-shadow: 0 5px 15px rgba(0, 200, 230, 0.1);
        }
        .contact-form button {
            background: var(--electric-blue);
            color: var(--white);
            padding: 1rem 2rem;
            border-radius: 50px;
            font-weight: 600;
            margin-top: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        .contact-form button:hover {
            background: #00b3d9;
        }
        footer {
            text-align: center;
            padding: 3rem 0;
            background: var(--charcoal);
            font-size: 0.9rem;
            margin-top: 2rem;
        }
        .footer-links {
            display: flex;
            justify-content: center;
            gap: 1rem;
            margin-top: 1rem;
        }
        .footer-links a {
            color: var(--electric-blue);
            text-decoration: none;
            transition: all 0.3s ease;
        }
        .footer-links a:hover {
            color: var(--white);
            transform: scale(1.05);
        }
        .mobile-menu {
            display: none;
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            padding: 1rem;
            background: var(--charcoal);
            text-align: center;
        }
        .mobile-menu a {
            display: block;
            padding: 0.5rem 0;
            text-decoration: none;
            color: var(--white);
        }
        .mobile-menu a:hover {
            color: var(--electric-blue);
        }
        .nav-bar {
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000;
            background: var(--charcoal);
            padding: 1rem 0;
            transition: all 0.3s ease;
        }
        .nav-bar.active {
            background: var(--dark-navy);
        }
        .nav-bar a {
            color: var(--white);
            text-decoration: none;
            padding: 0.5rem 1rem;
            border-radius: 5px;
            transition: all 0.3s ease;
        }
        .nav-bar a:hover {
            background: var(--electric-blue);
            color: var(--white);
            transform: translateY(-2px);
            box-shadow: 0 5px 10px rgba(0, 200, 230, 0.3);
        }
        .nav-links {
            display: flex;
            justify-content: space-around;
            list-style: none;
        }
        .nav-links li {
            margin: 0;
            padding: 0;
            position: relative;
        }
        .nav-links a {
            text-decoration: none;
            position: relative;
        }
        .nav-links a:hover::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 2px;
            background: var(--electric-blue);
            transform: scaleX(0);
            transition: transform 0.3s ease;
        }
        .nav-links a:hover::after {
            transform: scaleX(1);
        }
        .menu-toggle {
            display: none;
            position: absolute;
            top: 0;
            right: 0;
            padding: 0.5rem;
            background: var(--charcoal);
            color: var(--white);
            z-index: 1000;
            font-weight: 700;
        }
        .menu-toggle:hover {
            color: var(--electric-blue);
        }
        #hero {
            position: relative;
            overflow: hidden;
        }
        #hero:before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, rgba(0, 200, 230, 0.1) 0%, rgba(0, 200, 230, 0.3) 50%, rgba(0, 200, 230, 0.1) 100%);
            z-index: -1;
        }
        .scroll-to-top {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            background: var(--electric-blue);
            color: var(--white);
            padding: 0.75rem;
            border-radius: 50%;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.3s ease;
            z-index: 1000;
        }
        .scroll-to-top:hover {
            background: #00b3d9;
            transform: scale(1.05);
        }
        .nav-bar,
        .mobile-menu {
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000;
        }
        .nav-bar .nav-links {
            justify-content: center;
        }
        .nav-links {
            padding: 0;
            margin: 0;
            list-style: none;
            display: flex;
            flex-direction: column;
            text-align: center;
        }
        .nav-links a {
            display: block;
            padding: 1rem 0;
            text-decoration: none;
        }
        .nav-links a:hover {
            color: var(--electric-blue);
            transform: translateY(-2px);
        }
        .mobile-menu {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: var(--charcoal);
            z-index: 1000;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }
        .mobile-menu a {
            display: block;
            margin: 1rem;
            padding: 0.75rem 1rem;
            text-decoration: none;
            color: var(--white);
        }
        .mobile-menu a:hover {
            color: var(--electric-blue);
        }
        .mobile-menu .close-btn {
            position: absolute;
            top: 1rem;
            right: 1rem;
            background: var(--electric-blue);
            color: var(--white);
            padding: 0.5rem;
            border-radius: 50%;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        .mobile-menu .close-btn:hover {
            background: #00b3d9;
            transform: scale(1.05);
        }
        @media (max-width: 768px) {
            .nav-bar {
                display: none;
            }
            .mobile-menu {
                display: flex;
            }
            .nav-links {
                display: flex;
                flex-direction: column;
                gap: 1rem;
            }
            .nav-links a {
                padding: 0.75rem 1rem;
            }
            .hero h1 {
                font-size: 2.5rem;
            }
            .hero p {
                font-size: 1.1rem;
                padding: 1rem;
            }
            .cta-btn {
                font-size: 1rem;
            }
        }
        @media (max-width: 480px) {
            .container {
                padding: 1rem;
            }
            .hero h1 {
                font-size: 2rem;
            }
            .hero p {
                font-size: 1rem;
            }
            .cta-btn {
                font-size: 0.9rem;
                padding: 0.75rem 1.5rem;
            }
            .mobile-menu {
                display: flex;
            }
        }
    </style>
</head>
<body>
    <div class="nav-bar" id="navBar">
        <div class="container">
            <a href="#" class="logo">Trainum Ops</a>
            <ul class="nav-links">
                <li><a href="#hero">Home</a></li>
                <li><a href="#services">Services</a></li>
                <li><a href="#industries">Industries</a></li>
                <li><a href="#featured">Featured</a></li>
                <li><a href="#about">About</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
            <div class="menu-toggle" id="menuToggle">☰</div>
        </div>
    </div>

    <section id="hero" class="hero">
        <div class="container">
            <h1>Trainum Optimization Partners</h1>
            <p>AI-Powered Optimization for Operations-Heavy Industries</p>
            <a href="#contact" class="cta-btn">Get Started</a>
        </div>
    </section>

    <section id="services" class="section">
        <div class="container">
            <h2 class="section-title">Our Services</h2>
            <div class="services">
                <div class="service-item">
                    <h3>Operational Optimization Consulting</h3>
                    <p>Route optimization, pricing strategy, workflow audits for logistics and property management.</p>
                </div>
                <div class="service-item">
                    <h3>AI Tool Development</h3>
                    <p>Custom AI dashboards, automated reporting, LLM-powered document generation for your team.</p>
                </div>
                <div class="service-item">
                    <h3>Safety & Compliance Solutions</h3>
                    <p>Fleet camera audits, driver safety programs, insurance-ready compliance reporting for hauling.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="industries" class="section">
        <div class="container">
            <h2 class="section-title">Target Industries</h2>
            <div class="industries">
                <ul>
                    <li>Waste & Hauling</li>
                    <li>Last-Mile Logistics</li>
                    <li>Property Management</li>
                </ul>
            </div>
        </div>
    </section>

    <section id="featured" class="section featured-offering">
        <div class="container">
            <h2 class="section-title">Featured Offering</h2>
            <p><strong>Safety-First Hauler Audit</strong> — 3-week engagement ($6K flat fee) where we audit your fleet’s safety setup and build an AI-powered compliance report you can show your insurance carrier to lower premiums.</p>
            <a href="#contact" class="cta">Schedule Your Audit</a>
        </div>
    </section>

    <section id="about" class="section">
        <div class="container">
            <h2 class="section-title">About Us</h2>
            <div class="about">
                <div class="item">
                    <h3>Josh Trainum</h3>
                    <p>15+ years in logistics optimization, AI tooling, and transportation pricing. We’ve built scalable systems that reduce costs and improve efficiency for fleets and property teams.</p>
                </div>
                <div class="item">
                    <h3>Tim Trainum</h3>
                    <p>10+ years in camera systems, fleet safety, and compliance in the waste/hauling industry. We ensure your operations are not only efficient, but also safe, compliant, and insurance-ready.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="contact" class="section">
        <div class="container">
            <h2 class="section-title">Contact</h2>
            <div class="contact-form">
                <form action="mailto:josh@trainumops.com" method="post" target="_blank" class="form">
                    <input type="text" placeholder="Your Name" name="name" required>
                    <input type="email" placeholder="Your Email" name="email" required>
                    <textarea placeholder="Your Message" name="message" required></textarea>
                    <button type="submit">Send Message</button>
                </form>
            </div>
        </div>
    </section>

    <footer>
        <div class="container">
            <p>© 2024 Trainum Optimization Partners. All Rights Reserved.</p>
            <div class="footer-links">
                <a href="https://facebook.com">Facebook</a>
                <a href="https://linkedin.com">LinkedIn</a>
                <a href="https://instagram.com">Instagram</a>
            </div>
        </div>
    </footer>

    <a href="#" class="scroll-to-top">↑</a>

    <script>
        // Smooth scroll to sections
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    window.scrollTo({
                        top: target.offsetTop,
                        behavior: 'smooth'
                    });
                }
            });
        });

        // Mobile menu toggle
        const menuToggle = document.getElementById('menuToggle');
        const navBar = document.getElementById('navBar');
        const mobileMenu = document.querySelector('.mobile-menu');

        if (menuToggle) {
            menuToggle.addEventListener('click', () => {
                navBar.classList.toggle('active');
                mobileMenu.classList.toggle('active');
            });
        }

        // Scroll to top
        const scrollBtn = document.querySelector('.scroll-to-top');
        window.addEventListener('scroll', () => {
            if (window.pageYOffset > 500) {
                scrollBtn.style.opacity = '1';
                scrollBtn.style.visibility = 'visible';
            } else {
                scrollBtn.style.opacity = '0';
                scrollBtn.style.visibility = 'hidden';
            }
        });
        scrollBtn.addEventListener('click', () => {
            window.scrollTo({
                top: 0,
                behavior: 'smooth'
            });
        });

        // Add active class to nav links on scroll
        const sections = document.querySelectorAll('section');
        const navLinks = document.querySelectorAll('.nav-links a');
        window.addEventListener('scroll', () => {
            let current = '';

            sections.forEach(section => {
                const top = section.offsetTop - 100;
                const bottom = top + section.offsetHeight;
                if (window.scrollY >= top && window.scrollY < bottom) {
                    current = section.getAttribute('id');
                }
            });

            navLinks.forEach(link => {
                if (link.getAttribute('href') === '#' + current) {
                    link.classList.add('active');
                } else {
                    link.classList.remove('active');
                }
            });
        });

        // Add hover effects for nav links
        document.querySelectorAll('.nav-links a').forEach(link => {
            link.addEventListener('mouseenter', () => {
                link.style.color = '#00b3d9';
            });
            link.addEventListener('mouseleave', () => {
                link.style.color = 'white';
            });
        });

        // Set initial active link
        const initialSection = document.querySelector('#hero');
        if (initialSection) {
            const heroLink = document.querySelector('a[href="#hero"]');
            if (heroLink) {
                heroLink.classList.add('active');
            }
        }

        // Form submission (mailto:)
        document.querySelector('.form').addEventListener('submit', function(e) {
            e.preventDefault();
            const formData = new FormData(this);
            const mailto = "mailto:josh@trainumops.com?subject=Contact Form Submission&body=" +
                encodeURIComponent(formData.get('name') + "\n" + formData.get('email') + "\n" + formData.get('message'));
            window.location.href = mailto;
        });

        // Add active class to current section
        const section = document.querySelector('section');
        if (section) {
            const currentSectionId = section.getAttribute('id');
            const navLink = document.querySelector(`a[href="#${currentSectionId}"]`);
            if (navLink) {
                navLink.classList.add('active');
            }
        }

        // Close mobile menu on click outside
        document.addEventListener('click', (e) => {
            if (e.target.closest('.mobile-menu') || e.target.closest('.nav-bar')) {
                return;
            }
            if (mobileMenu.classList.contains('active')) {
                mobileMenu.classList.remove('active');
                navBar.classList.remove('active');
            }
        });
    </script>
</body>
</html>
